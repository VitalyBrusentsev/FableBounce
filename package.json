{
  "name": "fablebounce",
  "version": "1.0.0",
  "description": "Fable canvas toy project",
  "scripts": {
    "postinstall": "dotnet tool restore",
    "start": "dotnet fable watch src/App.fsproj -s --sourceMapsRoot src --run webpack serve --mode development",
    "build": "dotnet fable src/App.fsproj && webpack --mode production"
  },
  "devDependencies": {
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^6.0.0"
  },
  "author": "Vitaly Brusentsev",
  "license": "ISC"
}
